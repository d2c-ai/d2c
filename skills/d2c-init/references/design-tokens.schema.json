{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://d2c.dev/design-tokens.schema.json",
  "title": "d2c Design Tokens",
  "description": "Schema for .claude/design-tokens/design-tokens.json generated by d2c-init",
  "type": "object",
  "required": [
    "d2c_schema_version",
    "framework",
    "meta_framework",
    "component_file_extension",
    "styling_approach"
  ],
  "properties": {
    "d2c_schema_version": {
      "type": "integer",
      "minimum": 1,
      "description": "Schema version number. Current version is 1."
    },
    "framework": {
      "type": "string",
      "enum": ["react", "vue", "svelte", "angular", "solid", "astro"],
      "description": "The detected frontend framework."
    },
    "meta_framework": {
      "type": "string",
      "enum": ["next", "nuxt", "sveltekit", "angular", "solidstart", "astro", "react", "vue", "svelte", "solid"],
      "description": "The meta-framework or standalone framework variant."
    },
    "component_file_extension": {
      "type": "string",
      "enum": [".tsx", ".vue", ".svelte", ".component.ts", ".astro"],
      "description": "The file extension for component files."
    },
    "styling_approach": {
      "type": "string",
      "enum": ["tailwind", "css-modules", "css-in-js", "vanilla-css", "mixed"],
      "description": "The primary styling approach used in the project."
    },
    "styling_config_path": {
      "type": "string",
      "description": "Path to the styling config file (e.g., tailwind.config.ts, theme.ts)."
    },
    "colors": {
      "type": "object",
      "description": "Color tokens extracted from the project. Keys are semantic names, values are color values.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "object" }
        ]
      }
    },
    "spacing": {
      "type": "object",
      "description": "Spacing scale tokens. Keys are scale names, values are spacing values.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "object" }
        ]
      }
    },
    "typography": {
      "type": "object",
      "description": "Typography tokens including font families, sizes, weights, and line heights.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "array" },
          { "type": "object" }
        ]
      }
    },
    "breakpoints": {
      "type": "object",
      "description": "Responsive breakpoint values. Keys are breakpoint names, values are sizes.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" }
        ]
      }
    },
    "shadows": {
      "type": "object",
      "description": "Box-shadow tokens. Keys are shadow names, values are shadow definitions.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "object" }
        ]
      }
    },
    "borders": {
      "type": "object",
      "description": "Border tokens including radii and widths.",
      "additionalProperties": {
        "oneOf": [
          { "type": "string" },
          { "type": "number" },
          { "type": "object" }
        ]
      }
    },
    "components": {
      "type": "array",
      "description": "Discovered reusable components in the project.",
      "items": {
        "type": "object",
        "required": ["name", "path", "description", "props"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "The component name."
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "File path relative to project root."
          },
          "description": {
            "type": "string",
            "description": "Description following the template: [Type] that [function]. Supports [props]."
          },
          "props": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Alphabetically sorted list of prop names."
          }
        },
        "additionalProperties": false
      }
    },
    "hooks": {
      "type": "array",
      "description": "Discovered shared hooks, composables, stores, or services.",
      "items": {
        "type": "object",
        "required": ["name", "path", "description"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "The hook/composable/service name."
          },
          "path": {
            "type": "string",
            "minLength": 1,
            "description": "File path relative to project root."
          },
          "description": {
            "type": "string",
            "description": "What it does."
          }
        },
        "additionalProperties": false
      }
    },
    "preferred_libraries": {
      "type": "object",
      "description": "Preferred libraries by capability category.",
      "additionalProperties": {
        "type": "object",
        "required": ["selected", "installed", "file_count"],
        "properties": {
          "selected": {
            "type": "string",
            "minLength": 1,
            "description": "The library the user chose for this category."
          },
          "installed": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "description": "All installed libraries in this category."
          },
          "file_count": {
            "type": "object",
            "description": "Number of source files using each library.",
            "additionalProperties": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "additionalProperties": false
      }
    },
    "api": {
      "type": "object",
      "description": "API-specific configuration detected in the project.",
      "properties": {
        "config_path": {
          "type": "string",
          "description": "Path to API config/setup file."
        },
        "query_client_path": {
          "type": "string",
          "description": "Path to QueryClient setup if using React Query/SWR."
        },
        "base_url_env": {
          "type": "string",
          "description": "Environment variable name for API base URL."
        },
        "response_envelope": {
          "type": "string",
          "description": "Consistent response shape across 3+ API responses, or 'none-detected'."
        },
        "auth_pattern": {
          "type": "string",
          "enum": ["axios-interceptor", "fetch-wrapper", "next-auth-session", "auth-header-manual", "none-detected"],
          "description": "How auth headers are injected."
        },
        "error_handling": {
          "type": "string",
          "enum": ["toast", "error-boundary", "inline-message", "console-only", "mixed", "none-detected"],
          "description": "How API errors are handled."
        },
        "loading_pattern": {
          "type": "string",
          "enum": ["react-query-isLoading", "swr-isLoading", "suspense", "useState-loading", "skeleton-component", "mixed", "none-detected"],
          "description": "How loading states are shown."
        }
      },
      "additionalProperties": false
    },
    "conventions": {
      "type": "object",
      "description": "Detected project coding conventions.",
      "properties": {
        "component_declaration": {
          "$ref": "#/definitions/convention_entry",
          "description": "Arrow function vs function declaration (react/solid only)."
        },
        "export_style": {
          "$ref": "#/definitions/convention_entry",
          "description": "Default export vs named export."
        },
        "type_definition": {
          "$ref": "#/definitions/convention_entry",
          "description": "Interface vs type alias (TypeScript only)."
        },
        "type_location": {
          "$ref": "#/definitions/convention_entry",
          "description": "Colocated vs separate file (TypeScript only)."
        },
        "file_naming": {
          "$ref": "#/definitions/convention_entry",
          "description": "PascalCase, kebab-case, or camelCase."
        },
        "import_ordering": {
          "type": "object",
          "required": ["value", "confidence"],
          "properties": {
            "value": {
              "oneOf": [
                {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "enum": ["framework", "external", "internal", "relative", "type", "style"]
                  }
                },
                {
                  "type": "string",
                  "enum": ["mixed"]
                }
              ],
              "description": "Ordered array of import group names, or 'mixed'."
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "override": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false
        },
        "css_utility_pattern": {
          "type": "object",
          "required": ["value", "confidence"],
          "properties": {
            "value": {
              "type": "string",
              "enum": ["raw_classes", "cn", "clsx", "cva", "twMerge", "cx", "mixed"],
              "description": "The CSS class utility wrapper used."
            },
            "wrapper_import": {
              "type": "string",
              "description": "Import path for the wrapper function."
            },
            "confidence": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "override": {
              "type": "boolean",
              "default": false
            }
          },
          "additionalProperties": false
        },
        "barrel_exports": {
          "$ref": "#/definitions/convention_entry",
          "description": "Whether component directories use barrel exports."
        },
        "test_location": {
          "$ref": "#/definitions/convention_entry",
          "description": "Colocated, separate, or none detected."
        },
        "props_pattern": {
          "$ref": "#/definitions/convention_entry",
          "description": "Destructured vs props object (react/solid only)."
        }
      },
      "additionalProperties": false
    },
    "figma_variables": {
      "type": "object",
      "description": "Figma Variables imported during init.",
      "properties": {
        "imported_from": {
          "type": "string",
          "description": "Figma file URL or key."
        },
        "mismatches": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "figma_value", "code_value", "status"],
            "properties": {
              "name": { "type": "string" },
              "figma_value": { "type": "string" },
              "code_value": { "type": "string" },
              "status": {
                "type": "string",
                "enum": ["flagged", "resolved"]
              }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "island_frameworks": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Island frameworks detected in Astro projects."
    }
  },
  "definitions": {
    "convention_entry": {
      "type": "object",
      "required": ["value", "confidence"],
      "properties": {
        "value": {
          "type": "string",
          "description": "The detected convention value."
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Detection confidence (0-1). Only enforced if > 0.6."
        },
        "override": {
          "type": "boolean",
          "default": false,
          "description": "True if the user manually set this value."
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
